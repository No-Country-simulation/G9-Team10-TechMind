Data/*.joblib
Data/*.h5
Data/*.hdf5
Data/venv/
Data/.venv/
Data/env/

# Python general
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Jupyter
.ipynb_checkpoints/

