# ─── Secrets & Env ───────────────────────────────────
.env
.env.*
!.env.example
*.local

# ─── Frontend (React / Vite) ──────────────────────────
front-end/node_modules/
front-end/.pnpm-store/
front-end/dist/
front-end/dist-ssr/
